#
# Snort3 configuration consumed by luci-app-snort3.
# This file is owned by the snort3 package on most builds; the options
# below are the subset the LuCI app reads and writes.
#

config snort 'snort'
	# Master enable flag for the LuCI app's notion of the service.
	option enabled '0'

	# Monitored network interface (e.g. br-lan, eth0, wan).
	option interface 'br-lan'

	# Operating mode: 'ids' (detect only) or 'ips' (detect + block).
	option mode 'ids'

	# DAQ acquisition method. afpacket = passive copy (IDS),
	# nfq = inline via netfilter queue (IPS), pcap = passive capture.
	option method 'afpacket'

	# Networks Snort treats as "home" and "external".
	option home_net '192.168.1.0/24'
	option external_net 'any'

	# Paths.
	option config_dir '/etc/snort'
	option config_file '/etc/snort/snort.lua'
	option rules_dir '/etc/snort/rules'
	option log_dir '/var/log/snort'

	# Fast-alert log read by the Alerts page.
	option alert_file '/var/log/snort/alert_fast.txt'

	# Subscription oinkcode. Leave empty to use the free community ruleset.
	option oinkcode ''

	# Automatic rule update schedule.
	# update_frequency: disabled | daily | weekly | monthly
	# update_day: 1-30 for monthly, 0-6 (Sun-Sat) for weekly, ignored for daily
	# update_hour: 0-23
	# update_minute: 0 | 15 | 30 | 45
	option update_frequency 'disabled'
	option update_day '1'
	option update_hour '3'
	option update_minute '0'

	# Extra Snort Lua appended verbatim to the generated config.
	option custom_config ''
