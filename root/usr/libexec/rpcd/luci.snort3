#!/bin/sh
#
# luci.snort3 - rpcd backend for luci-app-snort3
#
# Implements the methods declared in the ACL. Called by rpcd in two modes:
#   <script> list            -> print the method table as JSON
#   <script> call <method>   -> read JSON args on stdin, print JSON result
#
# All JSON is produced with libubox/jshn to stay safe against quoting issues.
#

. /usr/share/libubox/jshn.sh

CONFIG=snort
SECTION=snort
UPDATE_STATUS=/tmp/snort3-update.json
UPDATE_WORKER=/usr/libexec/snort3-update.sh
INIT_SCRIPT=/etc/init.d/snort
SNORT_BIN="$(command -v snort 2>/dev/null || echo /usr/bin/snort)"

# ---- small helpers --------------------------------------------------------

uci_get() { uci -q get "${CONFIG}.${SECTION}.$1" 2>/dev/null; }

# Derive the subscriber snapshot file name that matches the installed Snort
# version, e.g. Snort 3.1.47.0 -> snortrules-snapshot-31470.tar.gz
rules_snapshot_name() {
	local v a b c d
	v="$("$SNORT_BIN" -V 2>&1 | sed -n 's/.*Version \([0-9][0-9.]*\).*/\1/p' | head -n1)"
	[ -z "$v" ] && return 1
	IFS=. read -r a b c d <<-EOF
		$v
	EOF
	: "${a:=0}"; : "${b:=0}"; : "${c:=0}"; : "${d:=0}"
	printf 'snortrules-snapshot-%s%s%02d%s.tar.gz' "$a" "$b" "$c" "$d"
}

snort_version() {
	"$SNORT_BIN" -V 2>&1 | sed -n 's/.*Version \([0-9][0-9.]*\).*/\1/p' | head -n1
}

# ---- methods --------------------------------------------------------------

method_getInterfaces() {
	# Enumerate network interfaces the UI can bind Snort to.
	local name
	json_init
	json_add_array interfaces
	for dev in /sys/class/net/*; do
		[ -e "$dev" ] || continue
		name="${dev##*/}"
		[ "$name" = lo ] && continue
		json_add_string "" "$name"
	done
	json_close_array
	json_dump
}

method_listRules() {
	# List the *.rules files in the rules dir plus the current active link
	# target, so the UI can manage the active.rules symlink without needing
	# direct filesystem ACL grants.
	local rules_dir active base
	rules_dir="$(uci_get rules_dir)"
	[ -z "$rules_dir" ] && rules_dir=/etc/snort/rules

	active=""
	[ -L "$rules_dir/active.rules" ] && active="$(readlink "$rules_dir/active.rules")"

	json_init
	json_add_string rules_dir "$rules_dir"
	json_add_string active "$active"
	json_add_array files
	if [ -d "$rules_dir" ]; then
		for f in "$rules_dir"/*.rules; do
			[ -f "$f" ] || continue
			base="${f##*/}"
			[ "$base" = active.rules ] && continue
			json_add_string "" "$base"
		done
	fi
	json_close_array
	json_dump
}

method_getStatus() {
	local pids pid mem total avail interface mode method enabled autostart
	local alert_file alert_count running ifstate

	interface="$(uci_get interface)"
	mode="$(uci_get mode)"
	method="$(uci_get method)"
	enabled="$(uci_get enabled)"
	alert_file="$(uci_get alert_file)"
	[ -z "$alert_file" ] && alert_file=/var/log/snort/alert_fast.txt

	# Running pids (sum RSS across all snort workers).
	pids="$(pgrep -x snort 2>/dev/null)"
	[ -z "$pids" ] && pids="$(pgrep -f "$SNORT_BIN" 2>/dev/null)"
	mem=0
	pid=""
	if [ -n "$pids" ]; then
		running=1
		pid="$(echo "$pids" | head -n1)"
		for p in $pids; do
			local rss
			rss="$(awk '/^VmRSS:/{print $2}' "/proc/$p/status" 2>/dev/null)"
			[ -n "$rss" ] && mem=$((mem + rss))
		done
	else
		running=0
	fi

	# System memory (kB).
	total="$(awk '/^MemTotal:/{print $2}' /proc/meminfo 2>/dev/null)"
	avail="$(awk '/^MemAvailable:/{print $2}' /proc/meminfo 2>/dev/null)"
	[ -z "$total" ] && total=0
	[ -z "$avail" ] && avail=0

	# Auto-start state via the init script.
	if "$INIT_SCRIPT" enabled 2>/dev/null; then autostart=1; else autostart=0; fi

	# Alert count.
	if [ -f "$alert_file" ]; then
		alert_count="$(wc -l < "$alert_file" 2>/dev/null | tr -d ' ')"
	fi
	[ -z "$alert_count" ] && alert_count=0

	# Interface link state.
	ifstate=down
	if [ -n "$interface" ] && [ -e "/sys/class/net/$interface/operstate" ]; then
		ifstate="$(cat "/sys/class/net/$interface/operstate" 2>/dev/null)"
	fi

	json_init
	json_add_boolean running "$running"
	json_add_string pid "$pid"
	json_add_int memory "$mem"
	json_add_int mem_total "$total"
	json_add_int mem_available "$avail"
	json_add_int alerts "$alert_count"
	json_add_string interface "${interface:-}"
	json_add_string interface_state "$ifstate"
	json_add_string mode "${mode:-ids}"
	json_add_string method "${method:-afpacket}"
	json_add_boolean enabled "${enabled:-0}"
	json_add_boolean autostart "$autostart"
	json_add_string version "$(snort_version)"
	json_dump
}

method_getAlerts() {
	local limit alert_file
	json_load "$(cat)"
	json_get_var limit limit
	[ -z "$limit" ] && limit=50

	alert_file="$(uci_get alert_file)"
	[ -z "$alert_file" ] && alert_file=/var/log/snort/alert_fast.txt

	json_init
	json_add_string file "$alert_file"
	json_add_array alerts
	if [ -f "$alert_file" ]; then
		tail -n "$limit" "$alert_file" 2>/dev/null | tac | while read -r line; do
			[ -z "$line" ] && continue
			json_add_string "" "$line"
		done
	fi
	json_close_array
	json_dump
}

method_getLog() {
	local limit
	json_load "$(cat)"
	json_get_var limit limit
	[ -z "$limit" ] && limit=100

	json_init
	json_add_array lines
	logread -e snort 2>/dev/null | tail -n "$limit" | while read -r line; do
		json_add_string "" "$line"
	done
	json_close_array
	json_dump
}

method_getRulesInfo() {
	local rules_dir count active mtime snapshot ver
	rules_dir="$(uci_get rules_dir)"
	[ -z "$rules_dir" ] && rules_dir=/etc/snort/rules

	count=0
	mtime=0
	if [ -d "$rules_dir" ]; then
		# Count rule signatures across all .rules files.
		count="$(grep -rhcE '^[[:space:]]*(alert|drop|reject|block|pass|log|sdrop)[[:space:]]' \
			"$rules_dir" 2>/dev/null | awk '{s+=$1} END{print s+0}')"
		mtime="$(find "$rules_dir" -name '*.rules' -printf '%T@\n' 2>/dev/null \
			| sort -nr | head -n1 | cut -d. -f1)"
	fi
	[ -z "$count" ] && count=0
	[ -z "$mtime" ] && mtime=0

	active=""
	[ -L "$rules_dir/active.rules" ] && active="$(readlink "$rules_dir/active.rules")"

	snapshot="$(rules_snapshot_name)"
	ver="$(snort_version)"

	json_init
	json_add_string rules_dir "$rules_dir"
	json_add_int rule_count "$count"
	json_add_int last_update "$mtime"
	json_add_string active_link "$active"
	json_add_string snort_version "$ver"
	json_add_string snapshot_name "$snapshot"
	json_add_string oinkcode "$(uci_get oinkcode)"
	json_add_boolean oinkcode_set "$([ -n "$(uci_get oinkcode)" ] && echo 1 || echo 0)"
	json_dump
}

method_serviceAction() {
	local action ok msg
	json_load "$(cat)"
	json_get_var action action

	ok=0
	msg=""
	case "$action" in
		start|stop|restart|reload)
			msg="$("$INIT_SCRIPT" "$action" 2>&1)" && ok=1
			;;
		enable)
			msg="$("$INIT_SCRIPT" enable 2>&1)" && ok=1
			uci -q set "${CONFIG}.${SECTION}.enabled=1"; uci -q commit "$CONFIG"
			;;
		disable)
			msg="$("$INIT_SCRIPT" disable 2>&1)" && ok=1
			;;
		*)
			msg="unknown action: $action"
			;;
	esac

	json_init
	json_add_boolean success "$ok"
	json_add_string action "$action"
	json_add_string message "$msg"
	json_dump
}

method_startUpdate() {
	# Refuse to start if a previous run is still active.
	if [ -f "$UPDATE_STATUS" ]; then
		if grep -q '"running":[[:space:]]*true' "$UPDATE_STATUS" 2>/dev/null; then
			json_init
			json_add_boolean started 0
			json_add_string message "An update is already running"
			json_dump
			return
		fi
	fi

	# Seed an initial status file and detach the worker.
	cat > "$UPDATE_STATUS" <<-EOF
		{"running":true,"phase":"queued","percent":0,"success":false,"message":"Queued","log":""}
	EOF

	setsid "$UPDATE_WORKER" >/dev/null 2>&1 &

	json_init
	json_add_boolean started 1
	json_add_string message "Update started"
	json_dump
}

method_getUpdateStatus() {
	if [ -f "$UPDATE_STATUS" ]; then
		cat "$UPDATE_STATUS"
	else
		echo '{"running":false,"phase":"idle","percent":0,"success":false,"message":"No update has been run yet","log":""}'
	fi
}

method_checkUpdate() {
	# A lightweight reachability probe against whichever ruleset would be
	# downloaded, so the UI can show remote size / last-modified (curl) or at
	# least confirm the server is reachable (uclient-fetch / wget).
	local oinkcode snapshot url headers size lastmod http tool reachable
	oinkcode="$(uci_get oinkcode)"

	if [ -n "$oinkcode" ]; then
		snapshot="$(rules_snapshot_name)"
		url="https://www.snort.org/rules/${snapshot}?oinkcode=${oinkcode}"
	else
		url="https://www.snort.org/downloads/community/snort3-community-rules.tar.gz"
	fi

	tool=""
	for c in curl uclient-fetch wget; do
		command -v "$c" >/dev/null 2>&1 && { tool="$c"; break; }
	done

	http=0; size=0; lastmod=""; reachable=0
	case "$tool" in
		curl)
			headers="$(curl -sIL --max-time 25 "$url" 2>/dev/null)"
			http="$(echo "$headers" | sed -n 's/^HTTP\/[0-9.]* \([0-9]*\).*/\1/p' | tail -n1)"
			size="$(echo "$headers" | tr -d '\r' | sed -n 's/^[Cc]ontent-[Ll]ength: \([0-9]*\)/\1/p' | tail -n1)"
			lastmod="$(echo "$headers" | tr -d '\r' | sed -n 's/^[Ll]ast-[Mm]odified: \(.*\)/\1/p' | tail -n1)"
			[ -n "$http" ] && [ "$http" -lt 400 ] 2>/dev/null && reachable=1
			;;
		uclient-fetch)
			uclient-fetch -q --spider --timeout=25 "$url" 2>/dev/null && reachable=1
			;;
		wget)
			wget -q --spider --timeout=25 "$url" 2>/dev/null && reachable=1
			;;
	esac
	[ -z "$http" ] && http=0
	[ -z "$size" ] && size=0

	json_init
	json_add_boolean reachable "$reachable"
	json_add_int http_status "${http:-0}"
	json_add_string source "$([ -n "$oinkcode" ] && echo subscription || echo community)"
	json_add_int remote_size "$size"
	json_add_string remote_modified "${lastmod:-}"
	json_add_string tool "${tool:-none}"
	json_dump
}

method_setOinkcode() {
	# Persist the subscription oinkcode. Stored verbatim (hex only) in uci.
	local code ok
	json_load "$(cat)"
	json_get_var code oinkcode
	# Oinkcodes are 40-char hex; strip anything else. Empty value clears it.
	code="$(printf '%s' "$code" | tr -cd '0-9a-fA-F')"
	if uci -q set "${CONFIG}.${SECTION}.oinkcode=$code" && uci -q commit "$CONFIG"; then
		ok=1
	else
		ok=0
	fi
	json_init
	json_add_boolean success "$ok"
	json_add_boolean set "$([ -n "$code" ] && echo 1 || echo 0)"
	json_add_string oinkcode "$code"
	json_dump
}

method_getSchedule() {
	local freq day hour minute
	freq="$(uci_get update_frequency)"
	day="$(uci_get update_day)"
	hour="$(uci_get update_hour)"
	minute="$(uci_get update_minute)"

	json_init
	json_add_string frequency "${freq:-disabled}"
	json_add_int day "${day:-1}"
	json_add_int hour "${hour:-0}"
	json_add_int minute "${minute:-0}"
	json_dump
}

method_setSchedule() {
	local freq day hour minute ok
	json_load "$(cat)"
	json_get_var freq frequency
	json_get_var day day
	json_get_var hour hour
	json_get_var minute minute

	# Sanitise
	case "$freq" in
		daily|weekly|monthly) ;;
		*) freq=disabled ;;
	esac
	day="$(printf '%s' "${day:-1}" | tr -cd '0-9')"
	hour="$(printf '%s' "${hour:-0}" | tr -cd '0-9')"
	minute="$(printf '%s' "${minute:-0}" | tr -cd '0-9')"
	[ -z "$day" ] && day=1
	[ -z "$hour" ] && hour=0
	[ -z "$minute" ] && minute=0
	# Clamp
	[ "$hour" -gt 23 ] 2>/dev/null && hour=23
	[ "$minute" -gt 59 ] 2>/dev/null && minute=59

	ok=0
	if uci -q batch <<-EOF
		set ${CONFIG}.${SECTION}.update_frequency='$freq'
		set ${CONFIG}.${SECTION}.update_day='$day'
		set ${CONFIG}.${SECTION}.update_hour='$hour'
		set ${CONFIG}.${SECTION}.update_minute='$minute'
		commit $CONFIG
	EOF
	then ok=1; fi

	# ---- update cron ----
	local CRON_ID="# luci-app-snort3 auto-update"
	local CRON_FILE="/etc/crontabs/root"
	[ -f "$CRON_FILE" ] || touch "$CRON_FILE"

	# Remove any existing entry
	sed -i "\|${CRON_ID}|d" "$CRON_FILE"

	if [ "$freq" != "disabled" ]; then
		local cron_line=""
		case "$freq" in
			daily)
				cron_line="${minute} ${hour} * * * ${UPDATE_WORKER} ${CRON_ID}"
				;;
			weekly)
				cron_line="${minute} ${hour} * * ${day} ${UPDATE_WORKER} ${CRON_ID}"
				;;
			monthly)
				# Clamp day to 1-30 for monthly
				[ "$day" -lt 1 ] 2>/dev/null && day=1
				[ "$day" -gt 30 ] 2>/dev/null && day=30
				cron_line="${minute} ${hour} ${day} * * ${UPDATE_WORKER} ${CRON_ID}"
				;;
		esac
		[ -n "$cron_line" ] && echo "$cron_line" >> "$CRON_FILE"
	fi

	# Reload crond so it picks up the change
	/etc/init.d/cron reload 2>/dev/null || killall -HUP crond 2>/dev/null

	json_init
	json_add_boolean success "$ok"
	json_add_string frequency "$freq"
	json_add_int day "$day"
	json_add_int hour "$hour"
	json_add_int minute "$minute"
	json_dump
}

method_linkRules() {
	# Point <rules_dir>/active.rules at the chosen ruleset file.
	local target rules_dir ok
	json_load "$(cat)"
	json_get_var target target
	rules_dir="$(uci_get rules_dir)"
	[ -z "$rules_dir" ] && rules_dir=/etc/snort/rules

	ok=0
	if [ -n "$target" ] && [ -f "$rules_dir/$target" ]; then
		ln -sf "$target" "$rules_dir/active.rules" && ok=1
	fi

	json_init
	json_add_boolean success "$ok"
	json_add_string target "$target"
	json_dump
}

# ---- dispatcher -----------------------------------------------------------

case "$1" in
	list)
		json_init
		json_add_object getInterfaces; json_close_object
		json_add_object listRules; json_close_object
		json_add_object getStatus; json_close_object
		json_add_object getAlerts;        json_add_int limit 0; json_close_object
		json_add_object getLog;           json_add_int limit 0; json_close_object
		json_add_object getRulesInfo; json_close_object
		json_add_object getUpdateStatus; json_close_object
		json_add_object checkUpdate; json_close_object
		json_add_object serviceAction;    json_add_string action ""; json_close_object
		json_add_object startUpdate; json_close_object
		json_add_object setOinkcode;      json_add_string oinkcode ""; json_close_object
		json_add_object getSchedule; json_close_object
		json_add_object setSchedule;      json_add_string frequency ""; json_add_int day 0; json_add_int hour 0; json_add_int minute 0; json_close_object
		json_add_object linkRules;        json_add_string target ""; json_close_object
		json_dump
		;;
	call)
		case "$2" in
			getInterfaces)    method_getInterfaces ;;
			listRules)        method_listRules ;;
			getStatus)        method_getStatus ;;
			getAlerts)        method_getAlerts ;;
			getLog)           method_getLog ;;
			getRulesInfo)     method_getRulesInfo ;;
			getUpdateStatus)  method_getUpdateStatus ;;
			checkUpdate)      method_checkUpdate ;;
			serviceAction)    method_serviceAction ;;
			startUpdate)      method_startUpdate ;;
			setOinkcode)      method_setOinkcode ;;
			getSchedule)      method_getSchedule ;;
			setSchedule)      method_setSchedule ;;
			linkRules)        method_linkRules ;;
			*)                echo '{"error":"unknown method"}' ;;
		esac
		;;
esac
